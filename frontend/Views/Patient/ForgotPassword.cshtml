@{
    ViewData["Title"] = "Patient Password Reset";
}

<div class="login-card login-form-card">

    <img src="~/images/logo.png" alt="MediTap Logo" class="logo" />
    <h1>Reset Password</h1>

    <p class="forgot-password-text">
        Enter your patient email address. The administrator will receive your password reset request.
    </p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    @if (ViewBag.Success != null)
    {
        <div class="alert alert-success">
            @ViewBag.Success
        </div>
    }

    <form asp-controller="Patient" asp-action="ForgotPasswordSubmit" method="post">

        <div class="form-group">
            <label>Email</label>
            <input type="email"
                   name="email"
                   placeholder="Enter your email"
                   required
                   oninvalid="this.setCustomValidity('Please enter a valid email address.')"
                   oninput="this.setCustomValidity('')" />
        </div>

        <button type="submit" class="btn btn-primary">
            Send Reset Request
        </button>

    </form>

    <a class="btn btn-success login-back-btn" href="/Patient/Login">
        Back to Patient Login
    </a>

</div>