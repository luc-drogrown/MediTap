@model MediTap.Front.Models.Admin.ManageAccountsPageViewModel

@{
    ViewData["Title"] = "Manage Accounts";
}

<div class="dashboard-layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <img src="~/images/logo.png" alt="MediTap Logo" class="sidebar-logo" />
            <span>MediTap</span>
        </div>

        <a class="sidebar-link" href="/Admin/RegisterPatient">Register Patient</a>
        <a class="sidebar-link" href="/Admin/RegisterMedic">Register Medic</a>
        <a class="sidebar-link" href="/Admin/ViewPatients">View Patients</a>
        <a class="sidebar-link" href="/Admin/ViewMedics">View Medics</a>
        <a class="sidebar-link active" href="/Admin/ManageAccounts">Manage Accounts</a>

        <a class="sidebar-link logout" href="/">Logout</a>
    </aside>

    <main class="dashboard-content manage-accounts-page">
        <div class="admin-page-header">
            <div class="admin-page-title-row">
                <h1>Manage Accounts</h1>

                <div class="admin-search-wrapper">
                    <span class="admin-search-icon">⌕</span>
                    <input id="adminSearchInput"
                           class="admin-search-input"
                           type="text"
                           placeholder="Search by name, email, role, or status..." />
                </div>
            </div>

            <p>Manage patient and medic accounts in the MediTap system.</p>
            @if (TempData["ManageAccountsError"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["ManageAccountsError"]
                </div>
            }

            @if (TempData["ManageAccountsSuccess"] != null)
            {
                <div class="alert alert-success">
                    @TempData["ManageAccountsSuccess"]
                </div>
            }
        </div>

        <section class="manage-reset-summary">
            <button id="toggleResetRequestsBtn"
                    type="button"
                    class="reset-summary-btn">
                <span>Password Reset Requests</span>
                <span class="status-badge status-pending">
                    @Model.PasswordResetRequests.Count pending
                </span>
            </button>

            <div id="resetRequestsPanel" class="reset-requests-panel" style="display: none;">
                <div class="dashboard-table-card small-table-card">
                    @if (Model.PasswordResetRequests == null || !Model.PasswordResetRequests.Any())
                    {
                        <p>No pending password reset requests.</p>
                    }
                    else
                    {
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th class="col-id">ID</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                    <th>Requested At</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in Model.PasswordResetRequests)
                                {
                                    <tr>
                                        <td>@request.Id</td>
                                        <td>@request.Email</td>
                                        <td>@request.Role</td>
                                        <td>@request.Status</td>
                                        <td>@request.RequestedAt.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>
                                            <button type="button"
                                                    class="table-action-btn"
                                                    onclick="openResetPasswordModal('@request.Id', '@request.Email', '@request.Role')">
                                                Reset
                                            </button>

                                            <form asp-controller="Admin"
                                                  asp-action="RejectPasswordReset"
                                                  method="post"
                                                  style="display:inline;">
                                                <input type="hidden" name="requestId" value="@request.Id" />
                                                <button type="submit" class="table-action-btn danger">
                                                    Reject
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </section>

        <section class="manage-section">
            <div class="manage-section-header">
                <div>
                    <h2>Accounts</h2>
                    <p>All patient and medic accounts currently registered.</p>
                </div>
            </div>

            <div class="dashboard-table-card accounts-table-card">
                @if (Model.Accounts == null || !Model.Accounts.Any())
                {
                    <p>No accounts found.</p>
                }
                else
                {
                    <table id="accountsTable" class="admin-table">
                        <thead>
                            <tr>
                                <th class="col-id">ID</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Role</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var account in Model.Accounts)
                            {
                                <tr>
                                    <td>@account.Id</td>
                                    <td>@account.FullName</td>
                                    <td>@account.Email</td>
                                    <td>@account.PhoneNumber</td>
                                    <td>@account.Role</td>
                                    <td>
                                        <span class="status-badge @(account.Status == "Active" ? "status-active" : "status-inactive")">
                                            @account.Status
                                        </span>
                                    </td>
                                    <td>
                                        @if (account.Status == "Active")
                                        {
                                            <form asp-controller="Admin"
                                                  asp-action="DisableAccount"
                                                  method="post"
                                                  style="display:inline;">
                                                <input type="hidden" name="accountId" value="@account.Id" />
                                                <input type="hidden" name="role" value="@account.Role" />

                                                <button type="submit" class="table-action-btn danger">
                                                    Disable
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-controller="Admin"
                                                  asp-action="EnableAccount"
                                                  method="post"
                                                  style="display:inline;">
                                                <input type="hidden" name="accountId" value="@account.Id" />
                                                <input type="hidden" name="role" value="@account.Role" />

                                                <button type="submit" class="table-action-btn">
                                                    Enable
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </section>
    </main>
</div>

<div id="resetPasswordModal" class="modal-overlay" style="display:none;">
    <div class="modal-card">
        <h2>Reset Password</h2>

        <p id="resetPasswordInfo" class="modal-subtitle"></p>

        <form asp-controller="Admin" asp-action="CompletePasswordReset" method="post">
            <input type="hidden" id="resetRequestId" name="requestId" />

            <div class="form-group">
                <label>New Password</label>
                <input type="password"
                       name="newPassword"
                       placeholder="Enter new password"
                       required />
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password"
                       name="confirmPassword"
                       placeholder="Confirm new password"
                       required />
            </div>

            <div class="modal-actions">
                <button type="button"
                        class="modal-btn modal-btn-secondary"
                        onclick="closeResetPasswordModal()">
                    Cancel
                </button>

                <button type="submit" class="modal-btn modal-btn-primary">
                    Save Password
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    function openResetPasswordModal(requestId, email, role) {
        const resetRequestId = document.getElementById("resetRequestId");
        const resetPasswordInfo = document.getElementById("resetPasswordInfo");
        const resetPasswordModal = document.getElementById("resetPasswordModal");

        if (!resetRequestId || !resetPasswordInfo || !resetPasswordModal) {
            return;
        }

        resetRequestId.value = requestId;
        resetPasswordInfo.innerText = `Set a new password for ${role}: ${email}`;
        resetPasswordModal.style.display = "flex";
    }

    function closeResetPasswordModal() {
        const resetPasswordModal = document.getElementById("resetPasswordModal");

        if (!resetPasswordModal) {
            return;
        }

        resetPasswordModal.style.display = "none";
    }

    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("adminSearchInput");
        const accountRows = document.querySelectorAll("#accountsTable tbody tr");

        if (searchInput) {
            searchInput.addEventListener("input", function () {
                const searchValue = searchInput.value.toLowerCase().trim();

                accountRows.forEach(row => {
                    const rowText = row.innerText.toLowerCase();

                    row.style.display = rowText.includes(searchValue)
                        ? ""
                        : "none";
                });
            });
        }

        const toggleResetRequestsBtn = document.getElementById("toggleResetRequestsBtn");
        const resetRequestsPanel = document.getElementById("resetRequestsPanel");

        if (toggleResetRequestsBtn && resetRequestsPanel) {
            toggleResetRequestsBtn.addEventListener("click", function () {
                const isHidden = resetRequestsPanel.style.display === "none";

                resetRequestsPanel.style.display = isHidden ? "block" : "none";
            });
        }
    });
</script>