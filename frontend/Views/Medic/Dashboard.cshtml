@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <img src="~/images/logo.png" alt="MediTap Logo" class="sidebar-logo" />
            <span>MediTap</span>
        </div>

        <a class="sidebar-link active" href="/Medic/Dashboard">Overview</a>
        <a class="sidebar-link" href="/Medic/Scan">Scan Card</a>
        <a class="sidebar-link logout" href="/">Logout</a>
